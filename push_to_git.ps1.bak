powershell -NoProfile -Command "& { try { [System.Management.Automation.Language.Parser]::ParseFile('d:\projects\git_rep\Blind_Log\push_to_git.ps1',[ref]$null,[ref]$null) | Out-Null; Write-Output 'PARSE_OK' } catch { Write-Output 'PARSE_ERROR:'; Write-Output $_.Exception.Message; exit 1 } }"# ================================
# PUSH + CHANGELOG + VERSION SCRIPT
# ================================
# Логика: сначала все вопросы, потом вся работа (add, commit с version/changelog, push)

# Настройка UTF-8
chcp 65001 | Out-Null
[Console]::OutputEncoding = [System.Text.Encoding]::UTF8
[Console]::InputEncoding  = [System.Text.Encoding]::UTF8
$ErrorActionPreference = "Stop"

# ===================================
# 1. ФАЗА ВОПРОСОВ — сначала всё спрашиваем
# ===================================
Write-Host "==============================="
Write-Host "🔍 Проверяем состояние репозитория"
Write-Host "==============================="

git fetch origin main 2>$null | Out-Null
$localCommits = git log origin/main..HEAD --oneline 2>$null

if ($localCommits) {
    Write-Host "Найдены локальные коммиты:"
    Write-Host $localCommits
    $msg = (git log -1 --pretty=%s 2>$null)
    Write-Host "Сообщение для нового коммита (из последнего): $msg"
}
else {
    $msg = Read-Host "Введите сообщение для коммита"
}

$msg = $msg.Trim()
if ([string]::IsNullOrWhiteSpace($msg)) {
    Write-Host "❌ Сообщение коммита не может быть пустым"
    exit 1
}

$changelogText = Read-Host "Что нового (для релиза)"
$tagConfirm    = Read-Host "Создать тег и релиз? (y/n)"

$doRelease = $false
$version   = ""

$tagTrim = $tagConfirm.Trim()
if ($tagTrim.Length -gt 0 -and $tagTrim.Substring(0,1).ToLower() -eq "y") {
    $doRelease = $true
    $version   = Read-Host "Введите версию (например, 2.8.1.0)"
    $version   = $version.Trim()
    if ([string]::IsNullOrWhiteSpace($version)) {
        Write-Host "❌ Версия не может быть пустой"
        exit 1
    }
}

# ===================================
# 2. ФАЗА РАБОТЫ — выполняем всё по порядку
# ===================================
Write-Host ""
Write-Host "==============================="
Write-Host "📦 Выполняем изменения"
Write-Host "==============================="

if ($doRelease) {
    # ---------- version.txt ----------
    Write-Host "✍️ Обновляем version.txt..."
    try {
        $parts = $version -split '\.'
        if ($parts.Count -lt 3) {
            Write-Host "❌ Версия должна быть в формате X.Y.Z или X.Y.Z.W"
            exit 1
        }
        $build = if ($parts.Count -ge 4) { $parts[3] } else { "0" }
        $tuple = "$($parts[0]), $($parts[1]), $($parts[2]), $build"

        $content = Get-Content version.txt -Raw -Encoding UTF8
        $content = $content -replace "(filevers=\()([^)]+)(\))", "`${1}$tuple`$3"
        $content = $content -replace "(prodvers=\()([^)]+)(\))", "`${1}$tuple`$3"
        $content = $content -replace "(FileVersion',\s*'[^']+')", "FileVersion', '$version'"
        $content = $content -replace "(ProductVersion',\s*'[^']+')", "ProductVersion', '$version'"

        Set-Content version.txt $content -Encoding UTF8NoBOM
        Write-Host "   version.txt обновлён"
    }
    catch {
        Write-Host "❌ Ошибка при обновлении version.txt: $_"
        exit 1
    }

    # ---------- changelog.txt ----------
    Write-Host "📝 Обновляем changelog.txt..."
    $block = @"
версия $version
изменения:
$changelogText

---

"@
    try {
        if (Test-Path changelog.txt) {
            $old = Get-Content changelog.txt -Raw -Encoding UTF8
            Set-Content changelog.txt ($block + $old) -Encoding UTF8
        }
        else {
            Set-Content changelog.txt $block -Encoding UTF8
        }
        Write-Host "   changelog.txt обновлён"
    }
    catch {
        Write-Host "❌ Ошибка при обновлении changelog.txt: $_"
        exit 1
    }
}

# ---------- git add + commit ----------
Write-Host "🧾 git add . && git commit..."
git add .
git commit -m "$msg"
if ($LASTEXITCODE -ne 0) {
    Write-Host "⚠️ Коммит не создан (возможно, нет изменений)"
}
else {
    Write-Host "   Коммит создан"
}

# ---------- push ----------
Write-Host ""
Write-Host "🚀 Пуш в origin main..."
git push origin main
if ($LASTEXITCODE -eq 0) {
    Write-Host "✅ Успешно запушено"
    exit 0
}

Write-Host "❌ Push не удался. Пробуем pull --rebase..."
git pull --rebase origin main
if ($LASTEXITCODE -ne 0) {
    Write-Host "❌ Rebase не удался. Останов."
    exit 1
}

git push origin main
if ($LASTEXITCODE -eq 0) {
    Write-Host "✅ Успешно запушено после ребейза"
}
else {
    Write-Host "❌ Push снова не удался. Проверь вручную."
    exit 1
}
